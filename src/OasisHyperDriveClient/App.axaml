<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OasisHyperDriveClient.ViewModels"
             x:Class="OasisHyperDriveClient.App"
             RequestedThemeVariant="Default">

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
        <StyleInclude Source="avares://OasisHyperDriveClient/Assets/Styles.axaml" />
    </Application.Styles>

    <Application.Resources>
        <!-- OASIS brand colours -->
        <Color x:Key="OasisCyan">#00FFEE</Color>
        <Color x:Key="OasisYellow">#FFD700</Color>
        <Color x:Key="OasisRed">#FF3333</Color>
        <Color x:Key="OasisGrey">#808080</Color>
        <Color x:Key="OasisBlue">#4488FF</Color>
        <Color x:Key="OasisPurple">#CC44FF</Color>
        <Color x:Key="OasisOrange">#FF8800</Color>
        <Color x:Key="BackgroundDark">#0D0D1A</Color>
        <Color x:Key="SurfaceDark">#151528</Color>
        <Color x:Key="BorderDark">#2A2A4A</Color>

        <SolidColorBrush x:Key="OasisCyanBrush" Color="{StaticResource OasisCyan}" />
        <SolidColorBrush x:Key="OasisYellowBrush" Color="{StaticResource OasisYellow}" />
        <SolidColorBrush x:Key="OasisRedBrush" Color="{StaticResource OasisRed}" />
        <SolidColorBrush x:Key="OasisGreyBrush" Color="{StaticResource OasisGrey}" />
        <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundDark}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceDark}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderDark}" />
    </Application.Resources>

    <NativeMenu.Menu>
        <NativeMenu x:DataType="vm:TrayIconViewModel">
            <NativeMenuItem Header="Open HyperDrive Browser"
                            Command="{Binding OpenBrowserCommand}" />
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="View Dashboard"
                            Command="{Binding OpenDashboardCommand}" />
            <NativeMenuItem Header="Settings"
                            Command="{Binding OpenSettingsCommand}" />
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="Sign Out"
                            Command="{Binding SignOutCommand}" />
            <NativeMenuItem Header="Quit"
                            Command="{Binding QuitCommand}" />
        </NativeMenu>
    </NativeMenu.Menu>
</Application>
