<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OasisHyperDriveClient.ViewModels"
        x:Class="OasisHyperDriveClient.Views.MetadataWindow"
        x:DataType="vm:MetadataViewModel"
        Title="Metadata"
        Width="520" Height="560"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Background="#0D0D1A">

    <Grid RowDefinitions="Auto,*,Auto" Margin="24">

        <!-- Title -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,20">
            <TextBlock Text="{Binding Holon.DisplayIcon, FallbackValue='🔷'}"
                       FontSize="32" />
            <TextBlock Text="{Binding Holon.Name}" FontSize="18" FontWeight="SemiBold"
                       Foreground="#E0E0FF" />
            <TextBlock Text="{Binding Holon.HolonType}" Foreground="#606080" FontSize="13" />
        </StackPanel>

        <!-- Metadata grid -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="20">

                <!-- Core fields -->
                <Border Background="#080818" CornerRadius="8" Padding="16">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                          ColumnDefinitions="140,*">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="ID" Classes="neon" FontSize="12" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Holon.Id}"
                                   Foreground="#808099" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Type" Classes="neon" FontSize="12" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Holon.HolonType}"
                                   Foreground="#C0C0DD" FontSize="12" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Size" Classes="neon" FontSize="12" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Holon.SizeDisplay}"
                                   Foreground="#C0C0DD" FontSize="12" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Created" Classes="neon" FontSize="12" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Text="{Binding Holon.Created, StringFormat='{}{0:dd MMM yyyy HH:mm} UTC', FallbackValue='—'}"
                                   Foreground="#C0C0DD" FontSize="12" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Modified" Classes="neon" FontSize="12" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="4" Grid.Column="1"
                                   Text="{Binding Holon.Modified, StringFormat='{}{0:dd MMM yyyy HH:mm} UTC', FallbackValue='—'}"
                                   Foreground="#C0C0DD" FontSize="12" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Provider" Classes="neon" FontSize="12" />
                        <TextBlock Grid.Row="5" Grid.Column="1"
                                   Text="{Binding Holon.PrimaryProvider, FallbackValue='—'}"
                                   Foreground="#C0C0DD" FontSize="12" />
                    </Grid>
                </Border>

                <!-- Provider keys -->
                <StackPanel Spacing="8">
                    <TextBlock Text="PROVIDER KEYS" FontSize="10" Foreground="#404060"
                               FontWeight="SemiBold" LetterSpacing="1.5" />
                    <ItemsControl ItemsSource="{Binding ProviderKeys}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#080818" CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                    <Grid ColumnDefinitions="120,*">
                                        <TextBlock Grid.Column="0" Text="{Binding Provider}"
                                                   Foreground="#00FFEE" FontSize="12" />
                                        <TextBlock Grid.Column="1" Text="{Binding Key}"
                                                   Foreground="#606080" FontSize="11"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Replication status -->
                <StackPanel Spacing="8">
                    <TextBlock Text="REPLICATION STATUS" FontSize="10" Foreground="#404060"
                               FontWeight="SemiBold" LetterSpacing="1.5" />
                    <ItemsControl ItemsSource="{Binding ReplicationStatus}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                                    <TextBlock Text="✓" Foreground="#00FFEE" FontSize="14" />
                                    <TextBlock Text="{Binding Provider}"
                                               Foreground="#C0C0DD" FontSize="12" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Button Grid.Row="2" Content="Close" Classes="primary"
                HorizontalAlignment="Right" Margin="0,16,0,0"
                Click="OnCloseClick" />
    </Grid>
</Window>
