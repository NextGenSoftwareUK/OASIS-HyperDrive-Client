<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OasisHyperDriveClient.ViewModels"
        x:Class="OasisHyperDriveClient.Views.DeleteConfirmDialog"
        x:DataType="vm:DeleteConfirmViewModel"
        Title="Delete" Width="380" Height="210"
        CanResize="False" WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="False">

    <Panel Background="#0D0D1A" Margin="20">
        <StackPanel Spacing="12" VerticalAlignment="Center">
            <TextBlock TextWrapping="Wrap" Foreground="#CCCCCC">
                <Run Text="Delete " />
                <Run Text="{Binding ItemName}" FontWeight="Bold" Foreground="White" />
                <Run Text="?" />
            </TextBlock>

            <RadioButton GroupName="DeleteMode" IsChecked="{Binding SoftDelete}"
                         Content="Move to trash (recoverable)" Foreground="#CCCCCC" />
            <RadioButton GroupName="DeleteMode" IsChecked="{Binding !SoftDelete}"
                         Content="Permanently delete" Foreground="#FF3333" />

            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="Cancel" Command="{Binding CancelCommand}" />
                <Button Classes="error" Content="Delete" Command="{Binding ConfirmCommand}" />
            </StackPanel>
        </StackPanel>
    </Panel>
</Window>
