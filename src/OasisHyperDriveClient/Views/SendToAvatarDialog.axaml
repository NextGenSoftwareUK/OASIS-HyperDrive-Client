<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OasisHyperDriveClient.ViewModels"
        x:Class="OasisHyperDriveClient.Views.SendToAvatarDialog"
        x:DataType="vm:SendToAvatarViewModel"
        Title="Send to Avatar" Width="440" Height="380"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="False">

    <Panel Background="#0D0D1A" Margin="16">
        <StackPanel Spacing="12">
            <TextBlock Foreground="#CCCCCC" TextWrapping="Wrap">
                <Run Text="Send " />
                <Run Text="{Binding ItemName}" FontWeight="Bold" Foreground="White" />
                <Run Text=" to avatar:" />
            </TextBlock>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox PlaceholderText="Search avatars…" Text="{Binding SearchQuery}"
                         MinWidth="280" />
                <Button Classes="primary" Content="Search"
                        Command="{Binding SearchCommand}" />
            </StackPanel>

            <ListBox ItemsSource="{Binding SearchResults}"
                     SelectedItem="{Binding SelectedAvatar}"
                     MaxHeight="200"
                     Background="#1A1A2E">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="👤" />
                            <TextBlock Text="{Binding Username}" Foreground="White" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Text="{Binding StatusMessage}" Foreground="#FF3333"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Content="Cancel" Command="{Binding CancelCommand}" />
                <Button Classes="primary" Content="Send"
                        Command="{Binding SendCommand}" />
            </StackPanel>
        </StackPanel>
    </Panel>
</Window>
